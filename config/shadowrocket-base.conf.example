# 把你的 Shadowrocket 完整模块配置粘贴到这里，保存为 shadowrocket-base.conf
# 脚本只会替换 [Script] 里 argument= 的经纬度/海拔/精度，其余内容（含 MITM 证书）原样保留
#
# Shadowrocket: YYYY-MM-DD HH:MM:SS
# [General]
# update-url = ...
#
# [Script]
# iOS Location Spoofer = ...argument=mode=response&latitude=...&longitude=...
#
# [MITM]
# ca-passphrase = ...
# ca-p12 = ...
# enable = true
# hostname = %APPEND% gs-loc.apple.com, ...
